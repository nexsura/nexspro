# -----------------------------------------------------------------------------
# Ruby / Rails
# -----------------------------------------------------------------------------
*.gem
*.rbc
.bundle/
vendor/bundle/

# Rails logs / tmp
log/*
tmp/*
!log/.keep
!tmp/.keep

# Rails storage / uploads
storage/*
!storage/.keep

# Rails generated assets
public/assets/
public/packs/
public/packs-test/
app/assets/builds/*
!app/assets/builds/.keep

# Rails credentials / secrets
/config/master.key
/config/credentials/*.key
/config/*.key

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Database
db/*.sqlite3
db/*.sqlite3-journal
db/*.sqlite3-shm
db/*.sqlite3-wal
*.sqlite3
*.sqlite3-journal

# Dumps / backups
*.sql
*.dump
*.backup
*.bak
*.tar
*.tar.gz
*.zip
*.7z
*.rar

# -----------------------------------------------------------------------------
# Tests / Coverage / Debug
# -----------------------------------------------------------------------------
coverage/
.rspec_status
.byebug_history
*.log

# Capybara / system test screenshots
tmp/screenshots/
tmp/capybara/

# SimpleCov / test artifacts
coverage.*
test/reports/
spec/reports/

# -----------------------------------------------------------------------------
# Node / Frontend tooling
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep lockfiles committed
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Docker / Dev Containers
# -----------------------------------------------------------------------------
.vscode-server/
.devcontainer/.cache/
.docker/
.cache/

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
.history/

# Ruby editor tooling
.ruby-lsp/
.solargraph/
.yardoc/
yardoc/
doc/

# -----------------------------------------------------------------------------
# Local machine files — NEVER commit these
# -----------------------------------------------------------------------------
.local/
.config/
.dotnet/
.gitconfig
.git-credentials
.gitkraken/
GitKraken/
.gk/
.gem/
.bundle/config

# SSH / certificates / keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

