#!/usr/bin/env ruby
# frozen_string_literal: true

require "uri"
require "English"

abort "Refusing to run CI in production." if ENV["RAILS_ENV"] == "production"

ENV["RAILS_ENV"] = "test"

if ENV["TEST_DATABASE_URL"]
  ENV["DATABASE_URL"] = ENV["TEST_DATABASE_URL"]
elsif ENV["DATABASE_URL"]
  database_url = URI.parse(ENV["DATABASE_URL"])
  database_url.path = database_url.path.sub(/_development\z/, "_test")
  ENV["DATABASE_URL"] = database_url.to_s
end

commands = [
  %w[bundle check],
  %w[bin/rails db:prepare],
  %w[bin/rails zeitwerk:check],
  %w[bin/rails routes],
  %w[bin/rails tailwindcss:build],
  %w[bin/rails assets:precompile],
  %w[bin/rubocop],
  %w[bin/brakeman --no-pager],
  %w[bin/bundler-audit check --update],
  %w[bin/rspec],
  %w[bin/rails db:seed:replant]
]

commands.each do |command|
  puts "\n==> #{command.join(' ')}"
  system(*command) || exit($CHILD_STATUS.exitstatus || 1)
end
