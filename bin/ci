#!/usr/bin/env bash
set -euo pipefail

if [[ "${RAILS_ENV:-}" == "production" ]]; then
  echo "Refusing to run CI in production." >&2
  exit 1
fi

export RAILS_ENV=test

if [[ -n "${TEST_DATABASE_URL:-}" ]]; then
  export DATABASE_URL="${TEST_DATABASE_URL}"
elif [[ -n "${DATABASE_URL:-}" && "${DATABASE_URL}" == *_development ]]; then
  export DATABASE_URL="${DATABASE_URL/%_development/_test}"
fi

run() {
  echo
  echo "==> $*"
  "$@"
}

run bundle check
run bin/rails db:prepare
run bin/rails zeitwerk:check
run bin/rails routes
run bin/rails db:migrate:status
run bundle exec rspec
run bin/rails tailwindcss:build
run bin/rails assets:precompile
run bin/rubocop
run bin/brakeman --no-pager
run bin/bundler-audit check --update
run bin/rails db:seed:replant
